        <mxCell id="ls4t" value="[候选]  原型通过才接入" style="text;html=1;align=left;verticalAlign=middle;fontSize=10;" vertex="1" parent="legend_status"><mxGeometry x="54" y="104" width="250" height="20" as="geometry" /></mxCell>
        <mxCell id="ls5" value="" style="rounded=0;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="legend_status"><mxGeometry x="14" y="130" width="30" height="16" as="geometry" /></mxCell>
        <mxCell id="ls5t" value="[待决策]  待负责人冻结（如 D01 聚合公式）" style="text;html=1;align=left;verticalAlign=middle;fontSize=10;" vertex="1" parent="legend_status"><mxGeometry x="54" y="128" width="260" height="20" as="geometry" /></mxCell>
